local function GetNearestEnemy(fromPos, range)
    local best, bestDist = nil, range
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if State.FriendList[plr.Name] then continue end
        local char = plr.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local d = (hrp.Position - fromPos).Magnitude
        if d < bestDist then bestDist = d; best = hrp end
    end
    return best
end

local function GetAllDoors()
    local list = {}
    local tiles = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Tiles")
    if not tiles then return list end
    for _, tile in ipairs(tiles:GetChildren()) do
        for _, obj in ipairs(tile:GetDescendants()) do
            if obj.Name == "DoorSystem" then table.insert(list, obj) end
        end
    end
    return list
end

local function GetUnoccupiedVehicles()
    local list = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("VehicleSeat") and not obj.Occupant then
            local model = obj.Parent
            if model and model:IsA("Model") then
                local root = model:FindFirstChild("VehicleBody")
                    or model:FindFirstChildWhichIsA("BasePart")
                if root then table.insert(list, root) end
            end
        end
    end
    return list
end

