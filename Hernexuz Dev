-- LOOP A — pull ผู้เล่นศัตรูเข้าหาตัวเอง
task.spawn(function()
    while true do
        task.wait(0.03)
        if not State.MagnetoEnabled then continue end
        local myChar = LocalPlayer.Character
        if not myChar then continue end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then continue end
        local myPos = myRoot.Position
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == LocalPlayer or not plr.Character then continue end
            if State.FriendList[plr.Name] then continue end
            local root = plr.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            local dist = (root.Position - myPos).Magnitude
            if dist > State.MagnetoRange or dist < 5 then continue end
            local dir = (myPos - root.Position).Unit
            local targetCF = CFrame.new(root.Position + dir * (dist * State.MagnetoSpeed))
            pcall(function() root:SetNetworkOwner(LocalPlayer) end)
            pcall(function() root.CFrame = root.CFrame:Lerp(targetCF, State.MagnetoSpeed * 2) end)
        end
    end
end)

