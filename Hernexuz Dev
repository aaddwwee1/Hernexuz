local EspObjects = {}

local function CleanEsp(plr)
    if EspObjects[plr] then
        for _, v in pairs(EspObjects[plr]) do
            pcall(function() if v and v.Parent then v:Destroy() end end)
        end
        EspObjects[plr] = nil
    end
end

local function MakeLbl(parent, posY, color)
    local l = Instance.new("TextLabel")
    l.Size=UDim2.new(1,0,0,18); l.Position=UDim2.new(0,0,0,posY)
    l.BackgroundTransparency=1; l.TextColor3=color
    l.Font=Enum.Font.GothamBold; l.TextSize=12
    l.TextStrokeTransparency=0.5; l.Text=""; l.Parent=parent
    return l
end

local function CreateEsp(plr)
    CleanEsp(plr)
    local char = plr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop=true; bb.Size=UDim2.new(0,160,0,80)
    bb.StudsOffset=Vector3.new(0,3.5,0); bb.Adornee=hrp; bb.Parent=workspace
    EspObjects[plr] = {
        bb        = bb,
        nameLbl   = MakeLbl(bb, 0,  Color3.fromRGB(255,80,80)),
        healthLbl = MakeLbl(bb, 20, Color3.fromRGB(80,255,80)),
        distLbl   = MakeLbl(bb, 40, Color3.fromRGB(160,160,255)),
        weaponLbl = MakeLbl(bb, 60, Color3.fromRGB(255,210,80)),
    }
end

RunService.Heartbeat:Connect(function()
    local anyEsp = State.EspName or State.EspHealth or State.EspDistance or State.EspWeapon
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local char = plr.Character
        if not char or not anyEsp then CleanEsp(plr) continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then CleanEsp(plr) continue end
        if not EspObjects[plr] then CreateEsp(plr) end
        local esp = EspObjects[plr]
        if not esp then continue end
        esp.nameLbl.Visible   = State.EspName
        if State.EspName then esp.nameLbl.Text = plr.Name end
        esp.healthLbl.Visible = State.EspHealth
        if State.EspHealth then esp.healthLbl.Text = string.format("HP %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth)) end
        esp.distLbl.Visible   = State.EspDistance
        if State.EspDistance then
            local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myHrp then esp.distLbl.Text = math.floor((hrp.Position-myHrp.Position).Magnitude).." m" end
        end
        esp.weaponLbl.Visible = State.EspWeapon
        if State.EspWeapon then
            local tool = char:FindFirstChildOfClass("Tool")
            esp.weaponLbl.Text = tool and ("⚔ "..tool.Name) or ""
        end
    end
end)

