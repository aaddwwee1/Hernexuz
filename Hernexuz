local KEY = getgenv().KEY or ""

local SCRIPT = "https://raw.githubusercontent.com/aaddwwee1/Hernexuz/refs/heads/main/Hernexuz%20Dev?token=GHSAT0AAAAAADXXQ4ELQN4TPST7PXKWS3FC2NUJFMQ"
local API = "http://192.168.1.36:3000/check"

local HttpService = game:GetService("HttpService")

local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

local data = {
    key = KEY,
    hwid = HWID
}

local response = request({
    Url = API,
    Method = "POST",
    Headers = {
        ["Content-Type"] = "application/json"
    },
    Body = HttpService:JSONEncode(data)
})

local result = HttpService:JSONDecode(response.Body)

if result.valid then
    loadstring(game:HttpGet(SCRIPT))()
else
    game.Players.LocalPlayer:Kick("Key Invalid / HWID Locked")
end
